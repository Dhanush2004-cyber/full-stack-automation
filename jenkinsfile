pipeline {

    agent any

    parameters {

        choice(
            name: 'BRANCH_NAME',
            choices: ['main', 'features'],
            description: 'Select branch to deploy'
        )

    }

    stages {

        stage('Deploy Application') {

            steps {

                sshPublisher(
                    publishers: [
                        sshPublisherDesc(

                            configName: 'Ubuntu',

                            verbose: true,

                            transfers: [

                                sshTransfer(

                                    execCommand: """
#!/bin/bash

set -e

echo "====================================="
echo "Starting Deployment"
echo "Branch : ${params.BRANCH_NAME}"
echo "====================================="

cd /home/master/project/full-stack-automation

echo "Fetching latest code..."

git fetch origin

git checkout ${params.BRANCH_NAME}

git reset --hard origin/${params.BRANCH_NAME}

echo "Installing Backend Dependencies..."

cd src/server

npm install

echo "Installing Frontend Dependencies..."

cd ../client

npm install

echo "Building React Application..."

rm -rf build

npm run build

echo "Updating Nginx..."

sudo rm -rf /var/www/fullstack/*

sudo cp -r build/* /var/www/fullstack/

echo "Restarting Backend..."

cd ../server

pm2 restart full-stack-backend

if pm2 describe full-stack-backend > /dev/null; then
    echo "Restarting PM2 application..."
    pm2 restart full-stack-backend
else
    echo "Starting PM2 application..."
    pm2 start bin/www --name full-stack-backend
fi

pm2 save


echo "Reloading Nginx..."

sudo systemctl reload nginx

echo "====================================="
echo "Deployment Successful"
echo "====================================="
"""

                                )

                            ]

                        )

                    ]

                )

            }

        }

    }

}